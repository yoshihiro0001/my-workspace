{
  "name": "template-repository",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "description": "GitHub Template: React + Tailwind + glass UI, subpath production deploy",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "start": "node server.js",
    "check": "tsc -b --noEmit",
    "bootstrap:derive": "node scripts/derive-from-repo-name.mjs"
  },
  "dependencies": {
    "express": "^4.21.0",
    "framer-motion": "^12.0.0",
    "lucide-react": "^0.468.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.16",
    "typescript": "~5.7.2",
    "vite": "^6.0.3"
  },
  "engines": {
    "node": ">=20"
  }
}
