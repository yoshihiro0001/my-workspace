{
  "name": "template-repository",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "description": "GitHub Template: React + Tailwind + glass UI, subpath production deploy",
  "scripts": {
    "dev": "concurrently -n api,vite -c blue,green \"node server/dev.js\" \"vite\"",
    "dev:api": "node server/dev.js",
    "dev:vite": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "start": "node server.js",
    "check": "tsc -b --noEmit",
    "bootstrap:derive": "node scripts/derive-from-repo-name.mjs"
  },
  "dependencies": {
    "adm-zip": "^0.5.17",
    "cors": "^2.8.6",
    "express": "^4.21.0",
    "framer-motion": "^12.0.0",
    "idb": "^8.0.3",
    "lucide-react": "^0.468.0",
    "multer": "^2.1.1",
    "prism-react-renderer": "^2.4.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "simple-git": "^3.36.0"
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "@types/adm-zip": "^0.5.8",
    "@types/multer": "^2.1.0",
    "@types/node": "^22.10.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.16",
    "typescript": "~5.7.2",
    "vite": "^6.0.3"
  },
  "engines": {
    "node": ">=20"
  }
}
